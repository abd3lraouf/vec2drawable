{
  "name": "@abd3lraouf/vec2drawable",
  "version": "1.1.3",
  "description": "Convert SVG files to Android VectorDrawable XML — pure TypeScript, no JDK required",
  "directories": {
    "lib": "dist",
    "test": "tests"
  },
  "files": [
    "dist",
    "cli.js"
  ],
  "bin": {
    "vec2drawable": "cli.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "prepack": "tsc",
    "prepublishOnly": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abd3lraouf/vec2drawable.git"
  },
  "keywords": [
    "android",
    "vector",
    "drawable",
    "svg",
    "vd-tool",
    "vec2drawable",
    "converter"
  ],
  "author": "abd3lraouf <https://github.com/abd3lraouf>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/abd3lraouf/vec2drawable/issues"
  },
  "homepage": "https://github.com/abd3lraouf/vec2drawable#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "proseWrap": "always"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "@types/svgo": "^3.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.12",
    "svgo": "^4.0.1"
  }
}
